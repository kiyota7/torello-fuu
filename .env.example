# docker-compose.prod.yml が読み込む環境変数のサンプル。
# コピーして .env という名前で保存し、実際の値を入力すること(.env はコミットしない)。
# 本番(EC2)では terraform の user_data がRDSのエンドポイントをもとに自動生成するため、
# このファイルはローカルでdocker-compose.prod.ymlを試す場合の参考用。

DB_URL=jdbc:postgresql://<RDSのエンドポイント>:5432/taskboard
DB_USERNAME=taskboard
DB_PASSWORD=change-me
